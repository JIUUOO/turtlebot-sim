FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble
ENV TURTLEBOT3_MODEL=burger

SHELL ["/bin/bash", "-c"]

# Install locale and basic system utilities.
RUN apt-get update && apt-get install -y --no-install-recommends \
    locales \
    curl \
    gnupg2 \
    lsb-release \
    ca-certificates \
    software-properties-common \
    && locale-gen en_US en_US.UTF-8 \
    && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# Add the official ROS 2 apt repository.
RUN curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
    -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo ${UBUNTU_CODENAME}) main" \
    > /etc/apt/sources.list.d/ros2.list

# Install ROS 2 Humble, Gazebo Sim integration, TurtleBot3 tools, and workspace tools.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-humble-ros-base \
    ros-humble-turtlesim \
    ros-humble-ros-gz \
    ros-humble-ros-gz-sim-demos \
    ros-humble-turtlebot3 \
    ros-humble-turtlebot3-description \
    ros-humble-turtlebot3-teleop \
    ros-humble-turtlebot3-cartographer \
    ros-humble-geometry-msgs \
    ros-humble-rcl-interfaces \
    ros-humble-sensor-msgs \
    ros-humble-std-srvs \
    python3-pip \
    python3-dev \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-vcstool \
    python3-numpy \
    python3-matplotlib \
    build-essential \
    cmake \
    git \
    vim \
    nano \
    net-tools \
    iputils-ping \
    lsof \
    && rm -rf /var/lib/apt/lists/*

# Initialize rosdep if it has not already been initialized.
RUN rosdep init || true

RUN pip3 install --no-cache-dir \
    openai \
    python-dotenv

WORKDIR /workspace/turtlebot-sim

COPY src ./src

RUN source /opt/ros/humble/setup.bash \
    && rosdep update \
    && rosdep install --from-paths src --ignore-src -r -y \
    && colcon build --symlink-install

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

RUN echo '' >> /root/.bashrc \
    && echo '# ROS 2 workspace setup' >> /root/.bashrc \
    && echo 'source /opt/ros/humble/setup.bash' >> /root/.bashrc \
    && echo 'export TURTLEBOT3_MODEL=burger' >> /root/.bashrc \
    && echo 'if [ -f /workspace/turtlebot-sim/install/setup.bash ]; then source /workspace/turtlebot-sim/install/setup.bash; fi' >> /root/.bashrc \
    && echo 'alias turtlews="cd /workspace/turtlebot-sim"' >> /root/.bashrc \
    && echo 'alias turtlesrc="source /workspace/turtlebot-sim/install/setup.bash"' >> /root/.bashrc \
    && echo 'alias turtlebuild="cd /workspace/turtlebot-sim && colcon build --symlink-install && source install/setup.bash"' >> /root/.bashrc

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
